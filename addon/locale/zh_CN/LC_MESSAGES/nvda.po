#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
msgid "BlueToothBatteryReport"
msgstr "蓝牙电量播报"

#. Translators: Long description to be shown for this add-on on add-on information from add-on store
msgid "Use the NVDA+Shift+= hotkey to report Bluetooth device battery levels."
msgstr "热键 NVDA+Shift+= 播报蓝牙设备电量。"

msgid "Reports the battery percentage of all local Bluetooth devices."
msgstr "播报本机所有蓝牙设备电量。"

msgid "Bluetooth battery detection failed."
msgstr "蓝牙电量检测失败。"

msgid "No Bluetooth battery information is available."
msgstr "没有可用的蓝牙电量信息。"

msgid "{name} battery {battery}%"
msgstr "{name} 电量 {battery}%"
